{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!assets/|.*\\.(?:js|css|png|jpg|jpeg|svg|webp|ico|json)).*)", "destination": "/index.html" }
  ]
}
